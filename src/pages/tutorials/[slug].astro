---
import { getCollection, render } from 'astro:content';
import TutorialLayout from '../../layouts/TutorialLayout.astro';

export async function getStaticPaths() {
  const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
  const sorted = allTutorials.sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  );

  return sorted.map((entry, index) => {
    const prevEntry = sorted[index - 1];
    const nextEntry = sorted[index + 1];
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: prevEntry && { slug: prevEntry.id, title: prevEntry.data.title },
        next: nextEntry && { slug: nextEntry.id, title: nextEntry.data.title },
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<TutorialLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  difficulty={entry.data.difficulty}
  heroImage={entry.data.heroImage}
  prev={prev}
  next={next}
>
  <Content />
</TutorialLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorialCard from '../../components/TutorialCard.astro';

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);

const categoryOrder = Array.from(
  new Set(allTutorials.map((t) => t.data.category ?? 'Uncategorized'))
).sort((a, b) => (a === 'Uncategorized' ? 1 : b === 'Uncategorized' ? -1 : a.localeCompare(b)));

const groups = categoryOrder.map((category) => ({
  category,
  tutorials: allTutorials
    .filter((t) => (t.data.category ?? 'Uncategorized') === category)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
}));
---
<BaseLayout
  title="All tutorials"
  description="Every hands-on tutorial on Tutorial Hub, grouped by category."
>
  <section class="tutorials-page">
    <div class="inner">
      <h1>All tutorials</h1>

      {
        groups.map(({ category, tutorials }) => (
          <div class="category-group" data-reveal>
            <h2>{category}</h2>
            <div class="grid">
              {tutorials.map((tutorial) => (
                <TutorialCard
                  slug={tutorial.id}
                  title={tutorial.data.title}
                  description={tutorial.data.description}
                  pubDate={tutorial.data.pubDate}
                  difficulty={tutorial.data.difficulty}
                />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .tutorials-page {
    padding: var(--space-8) 0 var(--space-9);
  }

  .inner {
    max-width: var(--content-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
  }

  .category-group + .category-group {
    margin-top: var(--space-8);
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-5);
    color: var(--text-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

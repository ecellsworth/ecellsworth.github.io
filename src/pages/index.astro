---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TutorialCard from '../components/TutorialCard.astro';

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const tutorials = allTutorials.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout
  title="Learn by building"
  description="Hands-on, no-fluff tutorials for shipping real things with modern AI tooling."
>
  <Hero />

  <section class="tutorials-section">
    <div class="inner">
      <h2 data-reveal>Latest tutorials</h2>
      <div class="grid">
        {
          tutorials.map((tutorial) => (
            <TutorialCard
              slug={tutorial.id}
              title={tutorial.data.title}
              description={tutorial.data.description}
              pubDate={tutorial.data.pubDate}
              difficulty={tutorial.data.difficulty}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tutorials-section {
    padding: var(--space-9) 0 var(--space-8);
  }

  .inner {
    max-width: var(--content-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
